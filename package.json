{
  "name": "medium-freedium-qr",
  "version": "1.2.0",
  "private": true,
  "description": "QR code generator for Medium articles that converts Medium links to Freedium links.",
  "scripts": {
    "prettier:check": "npx prettier **/*.{md,html,json} --check",
    "lint": "eslint **/*.js --no-warn-ignored",
    "zip": "cd src && zip -r ../medium-freedium-qr.zip . -x '*.DS_Store' && cd ..",
    "prerelease": "npm run lint && npm run prettier:check",
    "release": "commit-and-tag-version",
    "release:dry": "commit-and-tag-version --dry-run",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/serzn1/medium-freedium-qr.git"
  },
  "keywords": [],
  "author": "serzn1",
  "license": "Apache 2.0",
  "bugs": {
    "url": "https://github.com/serzn1/medium-freedium-qr/issues"
  },
  "homepage": "https://github.com/serzn1/medium-freedium-qr#readme",
  "devDependencies": {
    "@eslint/js": "9.19.0",
    "chrome-types": "0.1.335",
    "commit-and-tag-version": "^12.7.1",
    "eslint": "9.19.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.4.1",
    "globals": "15.14.0",
    "husky": "9.1.6",
    "lint-staged": "15.2.10",
    "prettier": "3.3.3"
  },
  "lint-staged": {
    "**/*.js": [
      "npx eslint --fix"
    ],
    "**/*.{md,html,json}": [
      "npx prettier --write"
    ]
  }
}
